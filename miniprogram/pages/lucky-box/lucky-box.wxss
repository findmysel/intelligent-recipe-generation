/* pages/lucky-box/lucky-box.wxss */
.container {
  padding: 30rpx;
  background: linear-gradient(135deg, #fff0f5 0%, #fff5e6 100%);
  min-height: 100vh;
}

.page-header {
  text-align: center;
  padding: 30rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #ff8c5a 100%);
  border-radius: 20rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 8rpx 30rpx rgba(255, 107, 53, 0.3);
}

.page-title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 10rpx;
}

.page-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.lucky-box-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.box-container {
  margin-bottom: 30rpx;
}

.box-outer {
  width: 300rpx;
  height: 300rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #ff8c5a 50%, #FFD700 100%);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 20rpx 60rpx rgba(255, 107, 53, 0.4);
  position: relative;
  overflow: hidden;
}

.box-outer::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: linear-gradient(45deg, transparent 40%, rgba(255, 255, 255, 0.3) 50%, transparent 60%);
  animation: shine 3s infinite;
}

@keyframes shine {
  0% { transform: translateX(-100%) rotate(45deg); }
  100% { transform: translateX(100%) rotate(45deg); }
}

.box-inner {
  width: 240rpx;
  height: 240rpx;
  background: linear-gradient(135deg, #fff 0%, #fff5f0 100%);
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.box-question {
  font-size: 120rpx;
  font-weight: bold;
  color: #FF6B35;
}

.box-sparkle {
  position: absolute;
  width: 40rpx;
  height: 40rpx;
  background: #FFD700;
  border-radius: 50%;
  animation: sparkle 1.5s infinite;
}

@keyframes sparkle {
  0%, 100% { transform: scale(0); opacity: 0; }
  50% { transform: scale(1); opacity: 1; }
}

.box-shake {
  animation: shake 0.5s ease-in-out infinite;
}

@keyframes shake {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-10rpx) rotate(-5deg); }
  75% { transform: translateX(10rpx) rotate(5deg); }
}

.box-desc {
  text-align: center;
  margin-bottom: 30rpx;
}

.desc-text {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.desc-sub {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.open-btn {
  padding: 24rpx 80rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #ff8c5a 100%);
  color: #fff;
  border-radius: 50rpx;
  font-size: 34rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 30rpx rgba(255, 107, 53, 0.4);
}

.btn-disabled {
  background: #ccc;
  box-shadow: none;
}

/* 结果卡片 */
.result-card {
  width: 100%;
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.1);
}

.result-header {
  text-align: center;
  margin-bottom: 20rpx;
}

.result-badge {
  display: inline-block;
  padding: 10rpx 30rpx;
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  color: #fff;
  border-radius: 30rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.result-emoji {
  text-align: center;
  font-size: 120rpx;
  margin-bottom: 16rpx;
}

.result-name {
  display: block;
  text-align: center;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.result-meta {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.meta-tag {
  padding: 8rpx 20rpx;
  background: #f8f8f8;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #666;
}

.result-info {
  background: #f8f4ff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.info-item {
  margin-bottom: 16rpx;
}

.info-item:last-child {
  margin-bottom: 0;
}

.info-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.info-value {
  display: block;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

.tips .info-value {
  color: #9b59b6;
}

.result-actions {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.action-btn {
  flex: 1;
  padding: 20rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: bold;
  text-align: center;
}

.primary {
  background: linear-gradient(135deg, #FF6B35 0%, #ff8c5a 100%);
  color: #fff;
}

.secondary {
  background: #fff;
  color: #FF6B35;
  border: 2rpx solid #FF6B35;
}

.reroll-btn {
  text-align: center;
  padding: 16rpx;
  font-size: 28rpx;
  color: #999;
}

/* 历史记录 */
.history-section {
  margin-top: 40rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.history-header {
  margin-bottom: 16rpx;
}

.history-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  transition: all 0.2s;
}

.history-arrow {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.history-info {
  flex: 1;
}

.history-name {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 4rpx;
}

.history-time {
  display: block;
  font-size: 22rpx;
  color: #999;
}

.history-go {
  font-size: 36rpx;
  color: #ccc;
}