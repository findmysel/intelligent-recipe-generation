/**pages/community/community.wxss**/
page { height: 100vh; display: flex; flex-direction: column; }
.page-container { display: flex; flex-direction: column; height: 100vh; }
.content-scroll { flex: 1; padding-bottom: 120rpx; }

/* 顶部Tab */
.top-tabs {
  display: flex;
  background: #fff;
  padding: 12rpx 16rpx;
  gap: 12rpx;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}
.top-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #666;
  border-radius: 12rpx;
}
.top-tab-active {
  color: #FF6B35;
  background: #FFF0EB;
  font-weight: 600;
}

/* 帖子列表 */
.post-list { padding: 12rpx 0; }
.post-card {
  background: #fff;
  margin: 12rpx 24rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.post-header { display: flex; align-items: center; margin-bottom: 16rpx; }
.post-avatar { font-size: 40rpx; margin-right: 12rpx; }
.post-user { flex: 1; }
.post-author { font-size: 28rpx; font-weight: 600; color: #333; display: block; }
.post-time { font-size: 22rpx; color: #bbb; }
.ai-badge {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 600;
}
.post-content { font-size: 28rpx; color: #333; line-height: 1.7; display: block; margin-bottom: 16rpx; }

/* 图片展示 */
.post-images {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 16rpx;
}
.post-image-item {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
}
.post-image-item.single {
  width: 300rpx;
  height: 300rpx;
}
.post-img { width: 100%; height: 100%; }

.post-recipe-link {
  display: flex;
  align-items: center;
  background: #FFF0EB;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}
.link-icon { font-size: 28rpx; margin-right: 8rpx; }
.link-name { flex: 1; font-size: 26rpx; color: #FF6B35; font-weight: 500; }
.link-arrow { font-size: 24rpx; color: #FF6B35; }
.post-actions { display: flex; gap: 32rpx; }
.post-action { display: flex; align-items: center; gap: 8rpx; }
.action-liked .action-icon-small { animation: heartbeat 0.6s ease-in-out; }
@keyframes heartbeat {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.3); }
}
.action-icon-small { font-size: 28rpx; }
.action-num { font-size: 24rpx; color: #999; }

/* 留言展示区 */
.post-comments {
  margin-top: 20rpx;
  background: #f8f8f8;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
}
.comment-item {
  margin-bottom: 8rpx;
  font-size: 26rpx;
  line-height: 1.5;
}
.comment-item:last-child {
  margin-bottom: 0;
}
.comment-author {
  color: #576b95;
  font-weight: 600;
}
.comment-content {
  color: #333;
}
/* 热门列表 */
.hot-list { padding: 12rpx 0; }
.hot-item {
  display: flex;
  align-items: center;
  background: #fff;
  margin: 12rpx 24rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.hot-rank {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #E0E0E0, #F5F5F5);
  color: #999;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
  margin-right: 16rpx;
}
.hot-item:nth-child(1) .hot-rank { background: linear-gradient(135deg, #FF4444, #FF6B35); color: #fff; }
.hot-item:nth-child(2) .hot-rank { background: linear-gradient(135deg, #FF8F5E, #FFB74D); color: #fff; }
.hot-item:nth-child(3) .hot-rank { background: linear-gradient(135deg, #FFB74D, #FFD54F); color: #fff; }
.hot-thumb {
  width: 100rpx;
  height: 100rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #FFE0D3, #FFF0EB);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}
.hot-emoji { font-size: 48rpx; }
.hot-info { flex: 1; }
.hot-name { font-size: 30rpx; font-weight: 600; color: #333; display: block; }
.hot-desc { font-size: 22rpx; color: #999; margin-top: 6rpx; display: block; }
.hot-stats { display: flex; align-items: center; gap: 6rpx; margin-top: 8rpx; }
.hot-rating { font-size: 24rpx; color: #FF6B35; font-weight: 600; }
.hot-count { font-size: 20rpx; color: #bbb; }

/* AI创想 */
.ai-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 24rpx 20rpx;
}
.ai-header-emoji { font-size: 64rpx; }
.ai-header-title { font-size: 34rpx; font-weight: 700; color: #333; margin-top: 12rpx; }
.ai-header-desc { font-size: 24rpx; color: #999; margin-top: 8rpx; text-align: center; }
.ai-list { padding: 0 24rpx; }
.ai-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  border-left: 6rpx solid #667eea;
}
.ai-card-top { display: flex; align-items: center; margin-bottom: 16rpx; }
.ai-emoji { font-size: 40rpx; margin-right: 16rpx; }
.ai-card-info { flex: 1; }
.ai-card-name { font-size: 30rpx; font-weight: 600; color: #333; display: block; }
.ai-card-meta { font-size: 22rpx; color: #999; margin-top: 4rpx; display: block; }
.ai-card-ingredients { display: flex; flex-wrap: wrap; align-items: center; gap: 8rpx; margin-bottom: 12rpx; }
.ai-ing-label { font-size: 22rpx; color: #999; }
.ai-ing-chip {
  font-size: 22rpx;
  color: #667eea;
  background: #F0F0FF;
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
}
.ai-card-preview { font-size: 26rpx; color: #666; line-height: 1.5; display: block; margin-bottom: 16rpx; }
.ai-card-btn { color: #667eea; font-size: 26rpx; font-weight: 500; text-align: right; }

/* FAB浮动按钮 */
.fab-btn {
  position: fixed;
  right: 40rpx;
  bottom: 180rpx;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF6B35, #FF8F5E);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(255,107,53,0.4);
  z-index: 50;
}

/* 弹窗 - 固定全屏覆盖式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 1000;
  display: none;
  align-items: flex-start;
  justify-content: center;
  padding-top: 100rpx;
}

.modal-show {
  display: flex;
}

.modal-content {
  background: #fff;
  width: 92%;
  max-height: 80vh;
  border-radius: 24rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.modal-header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}
.modal-title { font-size: 34rpx; font-weight: 700; color: #333; }
.modal-close-icon { font-size: 36rpx; color: #999; padding: 10rpx; }

.modal-scroll {
  flex: 1;
  max-height: calc(80vh - 200rpx);
  padding: 0 30rpx;
}

/* 图片选择区域 */
.image-select-area {
  padding: 20rpx 0;
}
.selected-image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.image-item {
  width: 150rpx;
  height: 150rpx;
  position: relative;
  border-radius: 12rpx;
  overflow: hidden;
}
.selected-img { width: 100%; height: 100%; }
.image-remove {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 36rpx;
  height: 36rpx;
  background: rgba(0,0,0,0.6);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
}
.add-image-btn {
  width: 150rpx;
  height: 150rpx;
  background: #f8f8f8;
  border: 2rpx dashed #ddd;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.add-icon { font-size: 48rpx; }
.add-text { font-size: 22rpx; color: #999; margin-top: 8rpx; }
.image-hint { font-size: 22rpx; color: #bbb; margin-top: 10rpx; }

.post-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx;
  border: 2rpx solid #eee;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  margin: 10rpx 0 20rpx;
  background: #fff;
}

.post-recipe-input { margin-bottom: 20rpx; }
.form-label-sm { font-size: 24rpx; color: #999; display: block; margin-bottom: 8rpx; }
.form-input-sm {
  width: 100%;
  padding: 16rpx;
  border: 2rpx solid #eee;
  border-radius: 12rpx;
  font-size: 26rpx;
  box-sizing: border-box;
  background: #fff;
}

.modal-btns {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 30rpx;
  border-top: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}
.modal-cancel {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border: 2rpx solid #ddd;
  border-radius: 40rpx;
  color: #999;
  font-size: 28rpx;
}
.modal-submit-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  background: linear-gradient(135deg, #FF6B35, #FF8F5E);
  border-radius: 40rpx;
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
}