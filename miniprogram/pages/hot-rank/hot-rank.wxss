/* pages/hot-rank/hot-rank.wxss */
.container {
  padding: 30rpx;
  background: linear-gradient(135deg, #fff8f0 0%, #fff5e6 100%);
  min-height: 100vh;
}

.page-header {
  text-align: center;
  padding: 30rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #ff8c5a 100%);
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(255, 107, 53, 0.3);
}

.page-title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 10rpx;
}

.page-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.period-tabs {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 8rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.period-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.3s;
}

.period-active {
  background: linear-gradient(135deg, #FF6B35 0%, #ff8c5a 100%);
  color: #fff;
  font-weight: bold;
}

.section-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.section-subtitle {
  font-size: 22rpx;
  color: #999;
}

.keyword-grid {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.keyword-item {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  transition: all 0.2s;
}

.keyword-rank {
  width: 50rpx;
  height: 50rpx;
  background: #e0e0e0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: bold;
  color: #999;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.rank-top {
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  color: #fff;
}

.keyword-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.keyword-count {
  font-size: 22rpx;
  color: #999;
}

.rank-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.rank-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  transition: all 0.2s;
}

.rank-number {
  width: 60rpx;
  height: 60rpx;
  background: #e0e0e0;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #666;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.rank-gold {
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  color: #fff;
}

.rank-emoji {
  font-size: 50rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.rank-info {
  flex: 1;
}

.rank-name {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 6rpx;
}

.rank-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: #999;
  margin-bottom: 6rpx;
}

.rank-dot {
  color: #ddd;
}

.rank-rating {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.star {
  font-size: 24rpx;
}

.rating-val {
  font-size: 24rpx;
  font-weight: bold;
  color: #FF6B35;
}

.rating-cnt {
  font-size: 22rpx;
  color: #999;
}

.rank-trend {
  font-size: 36rpx;
  margin-left: 16rpx;
}

.trend-hot {
  animation: pulse 1.5s infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.2); }
}