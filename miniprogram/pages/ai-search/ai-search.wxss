/* pages/ai-search/ai-search.wxss */
.container {
  padding: 30rpx;
  background: linear-gradient(135deg, #f8f4ff 0%, #f0f0ff 100%);
  min-height: 100vh;
}

.ai-header {
  text-align: center;
  padding: 40rpx 30rpx;
  background: linear-gradient(135deg, #9b59b6 0%, #8e44ad 100%);
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(155, 89, 182, 0.3);
}

.ai-title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
}

.ai-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.selected-bar {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.05);
}

.selected-label {
  font-size: 26rpx;
  color: #999;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.selected-tags {
  flex: 1;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.selected-tag {
  padding: 6rpx 16rpx;
  background: #f0f0f0;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #666;
}

.method-tag {
  background: #fff0e8;
  color: #FF6B35;
}

.cuisine-tag {
  background: #f0e8ff;
  color: #9b59b6;
}

.clear-btn {
  font-size: 24rpx;
  color: #999;
  padding: 8rpx 16rpx;
  flex-shrink: 0;
}

.tab-header {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 8rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.05);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.3s;
}

.tab-active {
  background: linear-gradient(135deg, #9b59b6 0%, #8e44ad 100%);
  color: #fff;
  font-weight: bold;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.card-hint {
  font-size: 24rpx;
  color: #999;
  font-weight: normal;
}

.ingredient-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.ingredient-item {
  width: 22%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 8rpx;
  border-radius: 12rpx;
  transition: all 0.2s;
}

.ingredient-emoji {
  font-size: 50rpx;
  margin-bottom: 8rpx;
  transition: transform 0.2s;
}

.ingredient-emoji-active {
  transform: scale(1.2);
}

.ingredient-name {
  font-size: 22rpx;
  color: #666;
  text-align: center;
}

.ingredient-name-active {
  color: #9b59b6;
  font-weight: bold;
}

.method-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.method-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: #f8f8f8;
  border-radius: 30rpx;
  transition: all 0.2s;
}

.method-active {
  background: linear-gradient(135deg, #9b59b6 0%, #8e44ad 100%);
}

.method-active .method-name {
  color: #fff;
}

.method-emoji {
  font-size: 32rpx;
}

.method-name {
  font-size: 26rpx;
  color: #666;
}

.cuisine-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.cuisine-item {
  padding: 10rpx 20rpx;
  background: #f0f0f0;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #666;
  transition: all 0.2s;
}

.cuisine-active {
  background: linear-gradient(135deg, #9b59b6 0%, #8e44ad 100%);
  color: #fff;
}

.search-btn-wrap {
  margin: 30rpx 0;
}

.search-btn {
  width: 100%;
  padding: 28rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
}

.ai-search-btn {
  background: linear-gradient(135deg, #9b59b6 0%, #8e44ad 100%);
  color: #fff;
  box-shadow: 0 8rpx 25rpx rgba(155, 89, 182, 0.4);
}

.result-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-top: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.result-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.result-icon {
  font-size: 50rpx;
}

.result-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.result-message {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.matched-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.matched-card {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  transition: all 0.2s;
}

.matched-emoji {
  font-size: 50rpx;
  margin-right: 20rpx;
}

.matched-info {
  flex: 1;
}

.matched-name {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 4rpx;
}

.matched-meta {
  font-size: 22rpx;
  color: #999;
}

.matched-arrow {
  font-size: 36rpx;
  color: #ccc;
}

.more-btn {
  text-align: center;
  padding: 20rpx;
  font-size: 28rpx;
  color: #9b59b6;
  font-weight: bold;
}

.ai-recipe-card {
  background: linear-gradient(135deg, #f8f4ff 0%, #f5f0ff 100%);
  border-radius: 16rpx;
  padding: 24rpx;
  border: 2rpx solid #e8e0ff;
}

.ai-recipe-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.ai-recipe-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.ai-badge {
  padding: 6rpx 16rpx;
  background: linear-gradient(135deg, #9b59b6 0%, #8e44ad 100%);
  color: #fff;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.ai-recipe-reason {
  font-size: 24rpx;
  color: #888;
  margin-bottom: 16rpx;
  font-style: italic;
}

.ai-recipe-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.ai-tag {
  padding: 6rpx 16rpx;
  background: #fff;
  color: #9b59b6;
  border-radius: 16rpx;
  font-size: 22rpx;
}

.ai-recipe-section {
  margin-bottom: 20rpx;
}

.section-label {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.section-value {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
  white-space: pre-wrap;
}

.ai-recipe-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.action-btn {
  flex: 1;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: bold;
  text-align: center;
}

.add-btn {
  background: linear-gradient(135deg, #9b59b6 0%, #8e44ad 100%);
  color: #fff;
}

.share-btn {
  background: #fff;
  color: #9b59b6;
  border: 2rpx solid #9b59b6;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  background: #fff;
  width: 80%;
  border-radius: 24rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 36rpx;
  color: #999;
}

.modal-body {
  padding: 30rpx;
}

.save-desc {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 20rpx;
  line-height: 1.6;
}

.save-info {
  background: #f8f4ff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.save-name {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.save-meta {
  display: block;
  font-size: 24rpx;
  color: #888;
}

.submit-btn {
  width: 100%;
  padding: 24rpx;
  background: linear-gradient(135deg, #9b59b6 0%, #8e44ad 100%);
  color: #fff;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
}