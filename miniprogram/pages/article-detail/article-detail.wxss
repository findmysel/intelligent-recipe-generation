/* pages/article-detail/article-detail.wxss */
.container {
  padding: 30rpx;
  padding-bottom: 120rpx;
  background: linear-gradient(135deg, #fff8f0 0%, #fff5e6 100%);
  min-height: 100vh;
}

.article-header {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.article-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.5;
  margin-bottom: 20rpx;
}

.article-meta-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.meta-dot {
  color: #ddd;
}

.article-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tag {
  padding: 6rpx 16rpx;
  background: linear-gradient(135deg, #fff0e8 0%, #fff5f0 100%);
  color: #FF6B35;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.rating-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.rating-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.rating-score {
  font-size: 36rpx;
  font-weight: bold;
  color: #FF6B35;
}

.rating-count {
  font-size: 24rpx;
  color: #999;
}

.rating-btn {
  padding: 12rpx 28rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #ff8c5a 100%);
  color: #fff;
  border-radius: 30rpx;
  font-size: 26rpx;
}

.tab-header {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 8rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.3s;
}

.tab-active {
  background: linear-gradient(135deg, #FF6B35 0%, #ff8c5a 100%);
  color: #fff;
  font-weight: bold;
}

.article-content {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.content-text {
  font-size: 30rpx;
  color: #444;
  line-height: 2;
  white-space: pre-wrap;
}

.comment-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.comment-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.comment-btn {
  padding: 10rpx 24rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #ff8c5a 100%);
  color: #fff;
  border-radius: 25rpx;
  font-size: 24rpx;
}

.comment-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.comment-item {
  display: flex;
  gap: 16rpx;
}

.comment-avatar {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #ff8c5a 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
}

.comment-body {
  flex: 1;
  border-bottom: 1rpx solid #f5f5f5;
  padding-bottom: 20rpx;
}

.comment-user {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.comment-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.comment-time {
  font-size: 22rpx;
  color: #999;
}

.comment-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
  display: block;
}

.empty-comments {
  text-align: center;
  padding: 60rpx 0;
}

.empty-icon {
  display: block;
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.empty-hint {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background: #fff;
  padding: 16rpx 30rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  justify-content: space-around;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.action-icon {
  font-size: 40rpx;
}

.action-text {
  font-size: 22rpx;
  color: #666;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.3s, visibility 0.3s;
}

.modal-visible {
  opacity: 1;
  visibility: visible;
}

.modal-hidden {
  opacity: 0;
  visibility: hidden;
}

.modal-content {
  background: #fff;
  width: 80%;
  border-radius: 24rpx;
  overflow: hidden;
}

.rating-modal, .comment-modal {
  width: 85%;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 36rpx;
  color: #999;
}

.modal-body {
  padding: 30rpx;
}

.rating-stars {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.star-icon {
  font-size: 60rpx;
  transition: transform 0.2s;
}

.star-active {
  transform: scale(1.2);
}

.rating-label {
  display: block;
  text-align: center;
  font-size: 28rpx;
  color: #FF6B35;
  font-weight: bold;
  margin-bottom: 24rpx;
}

.comment-input {
  width: 100%;
  padding: 20rpx;
  border: 2rpx solid #eee;
  border-radius: 12rpx;
  font-size: 28rpx;
  height: 200rpx;
  box-sizing: border-box;
  margin-bottom: 20rpx;
}

.submit-btn {
  width: 100%;
  padding: 24rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #ff8c5a 100%);
  color: #fff;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
}