/**pages/profile/profile.wxss**/
page { height: 100vh; display: flex; flex-direction: column; }
.scrollarea { flex: 1; }
.container { padding-bottom: 120rpx; }

/* 用户头部 */.profile-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: linear-gradient(135deg, #FF6B35, #FF8F5E);
  padding: 48rpx 24rpx 40rpx;
  border-radius: 0 0 40rpx 40rpx;
}
.profile-avatar { font-size: 80rpx; }
.profile-name { font-size: 34rpx; font-weight: 700; color: #fff; margin-top: 12rpx; }
.profile-desc { font-size: 24rpx; color: rgba(255,255,255,0.8); margin-top: 8rpx; }
.profile-stats {
  display: flex;
  align-items: center;
  margin-top: 28rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 20rpx;
  padding: 16rpx 48rpx;
}
.stat-item { display: flex; flex-direction: column; align-items: center; }
.stat-num { font-size: 36rpx; font-weight: 700; color: #fff; }
.stat-label { font-size: 22rpx; color: rgba(255,255,255,0.8); margin-top: 4rpx; }
.stat-divider { width: 1rpx; height: 48rpx; background: rgba(255,255,255,0.3); margin: 0 48rpx; }

/* 菜单 */
.menu-card {
  background: #fff;
  margin: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  overflow: hidden;
}
.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.menu-item:last-child { border-bottom: none; }
.menu-icon { font-size: 36rpx; margin-right: 16rpx; }
.menu-text { flex: 1; font-size: 28rpx; color: #333; }
.menu-arrow { font-size: 24rpx; color: #ccc; }

/* Tab切换 */
.content-tabs { display: flex; gap: 16rpx; padding: 0 24rpx; margin-bottom: 16rpx; }
.ctab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666;
  background: #fff;
  border-radius: 12rpx;
  border: 2rpx solid #eee;
}
.ctab-active {
  color: #FF6B35;
  border-color: #FF6B35;
  background: #FFF0EB;
  font-weight: 600;
}

/* 空状态 */
.empty-state { text-align: center; padding: 60rpx 0; }
.empty-icon { display: block; font-size: 80rpx; margin-bottom: 16rpx; }
.empty-text { display: block; font-size: 28rpx; color: #666; margin-bottom: 10rpx; }
.empty-hint { display: block; font-size: 24rpx; color: #999; }
.empty-btn { margin-top: 20rpx; padding: 16rpx 48rpx; font-size: 28rpx; }

/* 食谱列表项 */
.my-recipe-item {
  display: flex;
  align-items: center;
  background: #fff;
  margin: 12rpx 24rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.mr-left { margin-right: 16rpx; }
.mr-emoji {
  width: 100rpx;
  height: 100rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #FFE0D3, #FFF0EB);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}
.mr-right { flex: 1; }
.mr-name { font-size: 30rpx; font-weight: 600; color: #333; display: block; }
.mr-tags { display: flex; gap: 8rpx; margin-top: 8rpx; flex-wrap: wrap; }
.mr-tag {
  font-size: 20rpx;
  color: #FF6B35;
  background: #FFF0EB;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}
.region-tag-sm { color: #4CAF50; background: #E8F5E9; }
.mr-meta { font-size: 22rpx; color: #999; margin-top: 8rpx; display: block; }
.mr-rating { display: flex; align-items: center; gap: 4rpx; margin-top: 8rpx; }
.mr-rating-num { font-size: 24rpx; color: #FF6B35; font-weight: 600; }

/* 登录/注册按钮 */
.login-btns { display: flex; gap: 24rpx; margin-top: 28rpx; }
.login-btn, .register-btn {
  padding: 16rpx 48rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
}
.login-btn { background: #fff; color: #FF6B35; }
.register-btn {
  background: rgba(255,255,255,0.25);
  color: #fff;
  border: 2rpx solid rgba(255,255,255,0.6);
}

/* 弹窗视觉重构 - 高级感系列 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  backdrop-filter: blur(8px); /* 毛玻璃效果 */
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}
.modal-mask-show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  width: 85%;
  background: #ffffff;
  border-radius: 40rpx;
  overflow: hidden;
  position: relative;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
  transform: translateY(40rpx);
  transition: all 0.3s cubic-bezier(0.18, 0.89, 0.32, 1.28);
}
.modal-mask-show .modal-content {
  transform: translateY(0);
}

/* 头部 Banner */
.modal-banner {
  background: linear-gradient(135deg, #FF6B35, #FF8F5E);
  padding: 60rpx 40rpx;
  text-align: center;
  color: #fff;
}
.banner-reg {
  background: linear-gradient(135deg, #4CAF50, #81C784);
}
.modal-banner-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}
.modal-banner-title {
  font-size: 40rpx;
  font-weight: bold;
}
.modal-banner-desc {
  font-size: 24rpx;
  opacity: 0.9;
  margin-top: 8rpx;
}

.modal-close-btn {
  position: absolute;
  top: 30rpx;
  right: 30rpx;
  color: rgba(255, 255, 255, 0.7);
  font-size: 32rpx;
  padding: 10rpx;
}

.modal-scroll {
  max-height: 60vh;
  padding: 40rpx;
  box-sizing: border-box;
}

/* 表单重构 - 修复渲染问题 */
.auth-form {
  margin-bottom: 40rpx;
}
.auth-item {
  margin-bottom: 32rpx;
}
.auth-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
  display: block;
}
.auth-input {
  height: 90rpx; /* 规范高度 */
  line-height: 90rpx;
  background: #F8F9FB;
  border-radius: 20rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
  color: #333;
  width: 100%;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}
.input-placeholder {
  color: #ccc;
  font-size: 26rpx;
}
.auth-input:focus {
  background: #fff;
  border-color: #FF6B35;
}

/* 提交按钮 */
.auth-submit-btn {
  height: 100rpx;
  background: linear-gradient(135deg, #FF6B35, #FF8F5E);
  color: #fff;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 10rpx 20rpx rgba(255, 107, 53, 0.3);
}
.auth-submit-btn:active {
  transform: scale(0.97);
  opacity: 0.9;
}

/* 切换底部 */
.auth-footer {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 40rpx;
  font-size: 24rpx;
  color: #999;
  gap: 12rpx;
  padding-bottom: 20rpx;
}
.auth-link {
  color: #FF6B35;
  font-weight: bold;
  text-decoration: underline;
}