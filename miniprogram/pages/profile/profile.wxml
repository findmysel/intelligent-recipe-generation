<!--pages/profile/profile.wxml - 个人中心页-->
<scroll-view class="scrollarea" scroll-y enhanced show-scrollbar="{{false}}">
  <view class="container">
    <!-- 用户头部 - 已登录 -->
    <view class="profile-header" wx:if="{{isLoggedIn}}">
      <view class="profile-avatar">👨‍🍳</view>
      <text class="profile-name">{{userInfo.nickname}}</text>
      <text class="profile-desc">用心做好每一道菜</text>
      <view class="profile-stats">
        <view class="stat-item">
          <text class="stat-num">{{stats.recipeCount}}</text>
          <text class="stat-label">我的食谱</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-num">{{stats.favoriteCount}}</text>
          <text class="stat-label">我的收藏</text>
        </view>
      </view>
    </view>

    <!-- 用户头部 - 未登录 -->
    <view class="profile-header" wx:if="{{!isLoggedIn}}">
      <view class="profile-avatar">👤</view>
      <text class="profile-name">未登录</text>
      <text class="profile-desc">登录后享受更多功能</text>
      <view class="login-btns">
        <view class="login-btn" bindtap="onShowLogin">登录</view>
        <view class="register-btn" bindtap="onShowRegister">注册</view>
      </view>
    </view>

    <!-- 功能入口 -->
    <view class="menu-card">
      <view class="menu-item" bindtap="onUploadTap">
        <text class="menu-icon">📝</text>
        <text class="menu-text">上传食谱</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="onClearData">
        <text class="menu-icon">🗑️</text>
        <text class="menu-text">清除本地数据</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item admin-item" bindtap="onAuditTap">
        <text class="menu-icon">🛡️</text>
        <text class="menu-text">审核中心</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" wx:if="{{isLoggedIn}}" bindtap="onLogout">
        <text class="menu-icon">🚪</text>
        <text class="menu-text">退出登录</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <!-- Tab切换 -->
    <view class="content-tabs">
      <view class="ctab {{activeTab === 'recipes' ? 'ctab-active' : ''}}" data-tab="recipes" bindtap="onTabChange">📋 我的食谱</view>
      <view class="ctab {{activeTab === 'favorites' ? 'ctab-active' : ''}}" data-tab="favorites" bindtap="onTabChange">❤️ 我的收藏</view>
    </view>

    <!-- 我的食谱 -->
    <view wx:if="{{activeTab === 'recipes'}}">
      <view wx:if="{{myRecipes.length === 0}}" class="empty-state">
        <text class="empty-icon">📝</text>
        <text class="empty-text">还没有上传食谱</text>
        <view class="btn-primary empty-btn" bindtap="onUploadTap">去上传</view>
      </view>
      <view wx:for="{{myRecipes}}" wx:key="id" class="my-recipe-item" data-id="{{item.id}}" bindtap="onRecipeTap">
        <view class="mr-left">
          <view class="mr-emoji">{{item.cookingMethod === '炒' ? '🍳' : item.cookingMethod === '蒸' ? '♨️' : item.cookingMethod === '煮' ? '🫕' : item.cookingMethod === '烤' ? '🔥' : item.cookingMethod === '炸' ? '🍟' : item.cookingMethod === '凉拌' ? '🥗' : item.cookingMethod === '炖' ? '🍲' : '🥘'}}</view>
        </view>
        <view class="mr-right">
          <text class="mr-name">{{item.name}}</text>
          <view class="mr-tags">
            <text class="mr-tag">{{item.cuisine}}</text>
            <text class="mr-tag">{{item.cookingMethod}}</text>
            <text class="mr-tag region-tag-sm" wx:if="{{item.region}}">{{item.region}}</text>
          </view>
          <text class="mr-meta">{{item.difficulty}} · {{item.time}}</text>
        </view>
      </view>
    </view>

    <!-- 我的收藏 -->
    <view wx:if="{{activeTab === 'favorites'}}">
      <view wx:if="{{favoriteRecipes.length === 0}}" class="empty-state">
        <text class="empty-icon">❤️</text>
        <text class="empty-text">还没有收藏食谱</text>
        <text class="empty-hint">浏览食谱时点击收藏</text>
      </view>
      <view wx:for="{{favoriteRecipes}}" wx:key="id" class="my-recipe-item" data-id="{{item.id}}" bindtap="onRecipeTap">
        <view class="mr-left">
          <view class="mr-emoji">{{item.cookingMethod === '炒' ? '🍳' : item.cookingMethod === '蒸' ? '♨️' : item.cookingMethod === '煮' ? '🫕' : item.cookingMethod === '烤' ? '🔥' : item.cookingMethod === '炸' ? '🍟' : item.cookingMethod === '凉拌' ? '🥗' : item.cookingMethod === '炖' ? '🍲' : '🥘'}}</view>
        </view>
        <view class="mr-right">
          <text class="mr-name">{{item.name}}</text>
          <view class="mr-tags">
            <text class="mr-tag">{{item.cuisine}}</text>
            <text class="mr-tag">{{item.cookingMethod}}</text>
          </view>
          <view class="mr-rating">
            <text class="star-active">★</text>
            <text class="mr-rating-num">{{item.rating}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</scroll-view>

<!-- 登录弹窗 - 视觉升级版 -->
<view class="modal-mask {{showLoginModal ? 'modal-mask-show' : ''}}" wx:if="{{showLoginModal}}" bindtap="onCloseLogin">
  <view class="modal-content" catchtap="stopProp">
    <view class="modal-banner">
      <view class="modal-banner-icon">🔐</view>
      <view class="modal-banner-title">欢迎回来</view>
      <view class="modal-banner-desc">登录后开启您的味蕾之旅</view>
    </view>
    <view class="modal-close-btn" bindtap="onCloseLogin">✕</view>
    
    <scroll-view class="modal-scroll" scroll-y>
      <view class="auth-form">
        <view class="auth-item">
          <text class="auth-label">昵称</text>
          <input class="auth-input" placeholder="请输入您的昵称" placeholder-class="input-placeholder" value="{{loginName}}" bindinput="onLoginNameInput" />
        </view>
        <view class="auth-item">
          <text class="auth-label">密码</text>
          <input class="auth-input" placeholder="请输入密码" placeholder-class="input-placeholder" password="{{true}}" value="{{loginPwd}}" bindinput="onLoginPwdInput" />
        </view>
      </view>
      
      <view class="auth-submit-btn" bindtap="onLogin">立即登录</view>
      
      <view class="auth-footer">
        <text>还没有账号？</text>
        <text class="auth-link" bindtap="onShowRegister">立即注册</text>
      </view>
    </scroll-view>
  </view>
</view>

<!-- 注册弹窗 - 视觉升级版 -->
<view class="modal-mask {{showRegisterModal ? 'modal-mask-show' : ''}}" wx:if="{{showRegisterModal}}" bindtap="onCloseRegister">
  <view class="modal-content" catchtap="stopProp">
    <view class="modal-banner banner-reg">
      <view class="modal-banner-icon">👨‍🍳</view>
      <view class="modal-banner-title">加入味道星球</view>
      <view class="modal-banner-desc">创建您的个人厨师档案</view>
    </view>
    <view class="modal-close-btn" bindtap="onCloseRegister">✕</view>
    
    <scroll-view class="modal-scroll" scroll-y>
      <view class="auth-form">
        <view class="auth-item">
          <text class="auth-label">选个好名字</text>
          <input class="auth-input" placeholder="2-10个字符" placeholder-class="input-placeholder" value="{{regName}}" bindinput="onRegNameInput" />
        </view>
        <view class="auth-item">
          <text class="auth-label">设置密码</text>
          <input class="auth-input" placeholder="至少4位" placeholder-class="input-placeholder" password="{{true}}" value="{{regPwd}}" bindinput="onRegPwdInput" />
        </view>
        <view class="auth-item">
          <text class="auth-label">确认密码</text>
          <input class="auth-input" placeholder="再次确认您的密码" placeholder-class="input-placeholder" password="{{true}}" value="{{regPwd2}}" bindinput="onRegPwd2Input" />
        </view>
      </view>
      
      <view class="auth-submit-btn" bindtap="onRegister">完成注册</view>
      
      <view class="auth-footer">
        <text>已有账号？</text>
        <text class="auth-link" bindtap="onSwitchToLogin">去登录</text>
      </view>
    </scroll-view>
  </view>
</view>