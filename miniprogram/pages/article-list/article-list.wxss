/* pages/article-list/article-list.wxss */
.container {
  padding: 30rpx;
  padding-bottom: 120rpx;
  background: linear-gradient(135deg, #fff8f0 0%, #fff5e6 100%);
  min-height: 100vh;
}

.page-header {
  text-align: center;
  padding: 30rpx 0;
  background: linear-gradient(135deg, #FF6B35 0%, #ff8c5a 100%);
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(255, 107, 53, 0.3);
}

.page-title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 10rpx;
}

.page-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.tab-header {
  display: flex;
  justify-content: space-around;
  background: #fff;
  border-radius: 16rpx;
  padding: 10rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.tab-item {
  padding: 16rpx 40rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.3s;
}

.tab-active {
  background: linear-gradient(135deg, #FF6B35 0%, #ff8c5a 100%);
  color: #fff;
  font-weight: bold;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 20rpx;
  border-left: 6rpx solid #FF6B35;
}

.top-article-card {
  background: linear-gradient(135deg, #FF6B35 0%, #ff8c5a 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 30rpx rgba(255, 107, 53, 0.3);
}

.top-article-cover {
  width: 140rpx;
  height: 140rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.cover-emoji { font-size: 80rpx; }
.cover-emoji-sm { font-size: 50rpx; }

.top-article-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.top-article-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.top-article-summary {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  flex: 1;
}

.top-article-meta {
  display: flex;
  align-items: center;
  gap: 20rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

.top-article-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.top-article-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.top-article-item:last-child { border-bottom: none; }

.item-rank {
  font-size: 36rpx;
  font-weight: bold;
  color: #FF6B35;
  margin-right: 24rpx;
  width: 60rpx;
}

.item-info { flex: 1; }

.item-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: block;
  margin-bottom: 8rpx;
}

.item-meta {
  display: flex;
  gap: 20rpx;
  font-size: 22rpx;
  color: #999;
}

.article-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.article-cover {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #fff5f0 0%, #fff0e8 100%);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.article-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.article-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.article-summary {
  font-size: 24rpx;
  color: #888;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  flex: 1;
}

.article-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 10rpx;
}

.tag {
  padding: 4rpx 12rpx;
  background: #fff0e8;
  color: #FF6B35;
  border-radius: 8rpx;
  font-size: 20rpx;
}

.article-meta {
  display: flex;
  align-items: center;
  gap: 20rpx;
  font-size: 22rpx;
  color: #999;
}

.mine-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.publish-btn {
  padding: 12rpx 28rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #ff8c5a 100%);
  color: #fff;
  border-radius: 30rpx;
  font-size: 26rpx;
}

.empty-tip {
  text-align: center;
  padding: 80rpx 0;
}

.empty-icon { display: block; font-size: 100rpx; margin-bottom: 20rpx; }
.empty-text { display: block; font-size: 32rpx; color: #666; margin-bottom: 10rpx; }
.empty-hint { display: block; font-size: 24rpx; color: #999; }

/* 弹窗 - 固定全屏覆盖式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  display: none;
  align-items: flex-start;
  justify-content: center;
  padding-top: 120rpx;
}

.modal-show {
  display: flex;
}

.modal-content {
  background: #fff;
  width: 90%;
  max-height: 75vh;
  border-radius: 24rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
  padding: 10rpx;
}

.modal-scroll {
  flex: 1;
  max-height: calc(75vh - 130rpx);
}

.modal-body {
  padding: 30rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  padding: 20rpx;
  border: 2rpx solid #eee;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background: #fff;
}

.form-textarea {
  width: 100%;
  padding: 20rpx;
  border: 2rpx solid #eee;
  border-radius: 12rpx;
  font-size: 28rpx;
  min-height: 400rpx;
  box-sizing: border-box;
  background: #fff;
}

.submit-btn {
  width: 100%;
  padding: 24rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #ff8c5a 100%);
  color: #fff;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  margin-top: 20rpx;
}