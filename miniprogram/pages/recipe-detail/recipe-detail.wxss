/**pages/recipe-detail/recipe-detail.wxss**/
page { height: 100vh; display: flex; flex-direction: column; }
.scrollarea { flex: 1; }

/* 顶部卡片 */
.hero-card {
  display: flex;
  align-items: flex-start;
  background: linear-gradient(135deg, #FF6B35, #FF8F5E);
  margin: 20rpx 24rpx;
  padding: 32rpx;
  border-radius: 24rpx;
  position: relative;
}
.hero-emoji { font-size: 80rpx; margin-right: 24rpx; }
.hero-info { flex: 1; }
.hero-name { font-size: 38rpx; font-weight: 700; color: #fff; display: block; }
.hero-tags { display: flex; flex-wrap: wrap; gap: 8rpx; margin-top: 12rpx; }
.hero-tag {
  background: rgba(255,255,255,0.25);
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
}
.hero-rating { display: flex; align-items: center; margin-top: 12rpx; gap: 4rpx; }
.hero-rating .star-active { font-size: 26rpx; }
.rating-text { font-size: 22rpx; color: rgba(255,255,255,0.9); margin-left: 4rpx; }
.hero-author { font-size: 22rpx; color: rgba(255,255,255,0.7); margin-top: 8rpx; display: block; }
.fav-btn {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  font-size: 44rpx;
}

/* 食材 */
.card-title-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16rpx; }
.card-title { font-size: 30rpx; font-weight: 600; color: #333; }
.ingredients-list { display: flex; flex-wrap: wrap; gap: 12rpx; }
.ing-chip {
  background: #FFF0EB;
  color: #FF6B35;
  font-size: 26rpx;
  padding: 10rpx 24rpx;
  border-radius: 20rpx;
}

/* 详情Tab */
.detail-tabs {
  display: flex;
  gap: 12rpx;
  padding: 0 24rpx;
  margin-top: 8rpx;
}
.dtab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 24rpx;
  color: #666;
  background: #fff;
  border-radius: 12rpx;
  border: 2rpx solid #eee;
}
.dtab-active {
  color: #FF6B35;
  border-color: #FF6B35;
  background: #FFF0EB;
  font-weight: 600;
}

/* 步骤 */
.steps-list { padding: 0; }
.step-item { display: flex; align-items: flex-start; margin-bottom: 24rpx; }
.step-item:last-child { margin-bottom: 0; }
.step-num {
  min-width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF6B35, #FF8F5E);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  margin-right: 16rpx;
  margin-top: 4rpx;
}
.step-text { flex: 1; font-size: 28rpx; color: #333; line-height: 1.6; }

/* 注意事项 */
.tips-content { padding: 16rpx; background: #FFFBF0; border-radius: 12rpx; border-left: 6rpx solid #FFB800; }
.tips-text { font-size: 28rpx; color: #666; line-height: 1.8; }

/* 饮食文化 */
.culture-content { padding: 16rpx; background: #F0F7FF; border-radius: 12rpx; border-left: 6rpx solid #2196F3; }
.culture-text { font-size: 28rpx; color: #555; line-height: 1.8; }

/* 评价 */
.review-btn { padding: 8rpx 24rpx; font-size: 24rpx; }
.no-review { text-align: center; padding: 32rpx 0; }
.no-review-text { font-size: 26rpx; color: #bbb; }
.review-item { padding: 20rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.review-item:last-child { border-bottom: none; }
.review-header { display: flex; align-items: center; }
.review-avatar { font-size: 40rpx; margin-right: 12rpx; }
.review-user-info { flex: 1; }
.review-username { font-size: 26rpx; font-weight: 600; color: #333; display: block; }
.review-time { font-size: 20rpx; color: #bbb; }
.review-stars { display: flex; }
.review-stars .star-active, .review-stars .star { font-size: 24rpx; }
.review-comment { font-size: 26rpx; color: #555; line-height: 1.6; margin-top: 12rpx; display: block; }

/* 地区标签 */
.region-tag {
  display: inline-block;
  background: #E8F5E9;
  color: #4CAF50;
  font-size: 28rpx;
  padding: 12rpx 24rpx;
  border-radius: 12rpx;
  font-weight: 600;
}

/* 底部返回 */
.bottom-back {
  display: flex;
  justify-content: center;
  padding: 32rpx 24rpx 48rpx;
}

/* 评价弹窗 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}
.modal-content {
  width: 85%;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
}
.modal-title { font-size: 34rpx; font-weight: 700; color: #333; display: block; margin-bottom: 32rpx; text-align: center; }
.score-row { display: flex; align-items: center; margin-bottom: 24rpx; }
.score-label { font-size: 28rpx; color: #333; }
.score-stars { display: flex; margin-left: 12rpx; }
.score-star { font-size: 40rpx; padding: 4rpx; }
.score-num { font-size: 28rpx; color: #FF6B35; font-weight: 600; margin-left: 12rpx; }
.review-textarea {
  width: 100%;
  min-height: 200rpx;
  border: 2rpx solid #eee;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}
.modal-btns { display: flex; gap: 20rpx; margin-top: 32rpx; }
.modal-cancel {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border: 2rpx solid #ddd;
  border-radius: 40rpx;
  color: #999;
  font-size: 28rpx;
}
.modal-submit { flex: 1; padding: 20rpx; font-size: 28rpx; border-radius: 40rpx; }

/* 营养看板 */
.nutrition-unit { font-size: 20rpx; color: #999; }
.nutrition-grid { display: flex; justify-content: space-between; margin-top: 10rpx; gap: 10rpx; }
.nutri-item {
  flex: 1;
  background: #F8F9FA;
  padding: 16rpx 8rpx;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border-bottom: 4rpx solid #eee;
}
.nutri-val { font-size: 28rpx; font-weight: 700; color: #FF6B35; }
.nutri-label { font-size: 20rpx; color: #666; margin-top: 4rpx; }
.nutri-item:nth-child(2) { border-bottom-color: #4CAF50; }
.nutri-item:nth-child(3) { border-bottom-color: #FFB800; }
.nutri-item:nth-child(4) { border-bottom-color: #2196F3; }
