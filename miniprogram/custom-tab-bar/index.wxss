/* custom-tab-bar/index.wxss */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 110rpx;
  display: flex;
  background: #ffffff;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  padding-top: 10rpx;
}

.tab-icon {
  font-size: 44rpx;
  line-height: 1;
  transition: transform 0.2s;
}

.tab-icon-active {
  transform: scale(1.15);
}

.tab-text {
  font-size: 22rpx;
  margin-top: 4rpx;
  transition: color 0.2s;
}

.tab-indicator {
  position: absolute;
  top: 4rpx;
  width: 40rpx;
  height: 6rpx;
  border-radius: 3rpx;
  background: linear-gradient(135deg, #FF6B35, #FF8F5E);
}
