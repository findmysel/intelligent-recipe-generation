/**app.wxss**/
page {
  background-color: #F5F5F5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.container {
  min-height: 100vh;
  padding-bottom: 120rpx;
  box-sizing: border-box;
}

/* 通用卡片样式 */
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin: 20rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

/* 主色调 */
.text-primary { color: #FF6B35; }
.bg-primary { background-color: #FF6B35; }

/* 按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, #FF6B35, #FF8F5E);
  color: #fff;
  border: none;
  border-radius: 40rpx;
  padding: 20rpx 40rpx;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
}

.btn-outline {
  background: transparent;
  color: #FF6B35;
  border: 2rpx solid #FF6B35;
  border-radius: 40rpx;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  text-align: center;
}

/* 标签样式 */
.tag {
  display: inline-block;
  background: #FFF0EB;
  color: #FF6B35;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}

.tag-active {
  background: #FF6B35;
  color: #fff;
}

/* 评分星星 */
.stars {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.star {
  font-size: 28rpx;
  color: #ddd;
}

.star-active {
  color: #FFD700;
}

/* Section标题 */
.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
  padding: 24rpx 24rpx 16rpx;
}

.section-subtitle {
  font-size: 24rpx;
  color: #999;
  margin-left: 12rpx;
  font-weight: 400;
}

/* 食材选择网格 */
.ingredient-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 16rpx;
}

.ingredient-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
}

.ingredient-emoji {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #F8F8F8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  border: 3rpx solid transparent;
  transition: all 0.2s;
}

.ingredient-emoji-active {
  border-color: #FF6B35;
  background: #FFF0EB;
  transform: scale(1.05);
}

.ingredient-name {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
}

.ingredient-name-active {
  color: #FF6B35;
  font-weight: 600;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 页内返回导航栏 */
.back-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}
.back-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 20rpx;
  background: #FFF0EB;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #FF6B35;
  font-weight: 500;
}
.back-arrow {
  font-size: 28rpx;
}
